{
  "name": "bus-tracker",
  "version": "1.0.0",
  "description": "Real-time bus tracking web app with OTP auth, route matching, and live updates",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "setup": "npm install && node -e \"require('fs').copyFileSync('.env.example','.env')\" && npm run seed"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-session": "^1.18.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "bus",
    "tracking",
    "real-time",
    "express",
    "mongodb",
    "socket.io"
  ],
  "license": "MIT"
}
